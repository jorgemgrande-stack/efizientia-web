# Efizientia SaaS — Variables de entorno
# Copia este fichero como .env y rellena los valores reales

# OBLIGATORIO en producción — cambiar a un string aleatorio largo
JWT_SECRET=cambia-esto-por-un-secreto-seguro-en-produccion

# Puerto del servidor Express (Railway lo sobreescribe automáticamente)
PORT=4000

# Ruta de la base de datos SQLite (relativa al cwd del proceso)
DB_PATH=server/data/efizientia.db

# URL base de la app (para los enlaces de invitación en emails)
APP_URL=http://localhost:3000

# SMTP para emails de invitación (dejar vacío para modo consola)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=tu-usuario@example.com
SMTP_PASS=tu-contraseña
SMTP_FROM="Efizientia <noreply@efizientia.es>"

# Admin inicial (solo para el seed script)
ADMIN_EMAIL=admin@efizientia.es
ADMIN_PASSWORD=CambiaMeInmediatamente2025!
